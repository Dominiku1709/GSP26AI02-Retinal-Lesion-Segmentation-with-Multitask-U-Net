# GPU Configuration
# Set to 'true' to enable GPU acceleration, 'false' to use CPU only
ENABLE_GPU=true

# Enable fallback to CPU if GPU loading fails
FALLBACK_TO_CPU=true

# Optional: Set CUDA_PATH explicitly if not in system PATH
# CUDA_PATH=C:\Program Files\NVIDIA GPU Computing Toolkit\CUDA\v12.8

# Optional: Set cuDNN path
# CUDNN_PATH=C:\path\to\cudnn

# Database
DATABASE_URL=sqlite:///./oct_app.db

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
