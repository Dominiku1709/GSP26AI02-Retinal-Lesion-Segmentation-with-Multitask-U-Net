# ============================================================
# SUBMISSION EXCLUSIONS — Heavy data & runtime artifacts
# ============================================================

# Data directories (submit subset separately)
data/
datasets/
dataset/
backend_2.0/data/

# Heavy database files (will recreate via seed_data.py)
backend_2.0/oct_app.db

# Runtime storage (uploaded images, generated masks)
backend_2.0/storage/*
!backend_2.0/storage/.gitkeep

# Python bytecode (redundant safety — covers nested dirs)
**/__pycache__/
**/*.pyc

# Jupyter notebooks checkpoints
.ipynb_checkpoints/
*.ipynb

# Large archive files
*.tar.gz
*.tar
*.rar
*.7z

# Model weights (submit via Model_Weights.zip separately)
backend_2.0/weights/*.pth
backend_2.0/weights/*.pt

# Verification/debug files at backend root level
backend_2.0/verify_fix.py
backend_2.0/quick_fix_gpu.py
