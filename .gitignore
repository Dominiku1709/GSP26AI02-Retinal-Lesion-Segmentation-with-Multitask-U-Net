# ============================================================
# DEVELOPMENT/DEBUG FILES - Not needed in production (S4 Final)
# ============================================================

# Root-level: ignore ALL scripts, archives, and shell files
# (only README.md, REQUIREMENTS_CHECK.txt, and dirs are kept)
/*.py
/*.zip
/*.ps1
/*.sh
/*.bat

